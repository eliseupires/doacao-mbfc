# Variáveis de Ambiente — Mercado Pago
# Copie este arquivo para .env e preencha com suas credenciais reais
# NÃO suba o arquivo .env para o GitHub

# Access Token (começa com APP_USR- em produção ou TEST- em sandbox)
# Encontre em: https://www.mercadopago.com.br/developers/panel/app → Credenciais → Produção
MP_ACCESS_TOKEN=APP_USR-COLOQUE-SEU-ACCESS-TOKEN-AQUI

# Public Key (usada no frontend para inicializar o Checkout Bricks)
# Encontre no mesmo lugar do Access Token
MP_PUBLIC_KEY=APP_USR-COLOQUE-SUA-PUBLIC-KEY-AQUI

# URL do seu site no Vercel (ex: https://farol-de-cristo.vercel.app)
SITE_URL=https://SEU-SITE.vercel.app
